# Total Gross Profit Generated Per Genre

total_gross_genre <- movies %>%
  select("genre", "gross")
 
 
# Top 5 movie genres with the most gross profit were Action, Comedy, Animation, Drama, and Adventure


total_gross_genre %>%
  group_by(genre) %>%
  summarize(gross = sum(gross, na.rm = TRUE))
  view(total_gross_genre)


